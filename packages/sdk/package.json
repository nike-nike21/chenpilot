{
  "name": "@chen-pilot/sdk-core",
  "version": "1.0.0",
  "description": "Core SDK for Chen Pilot cross-chain operations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*",
    "examples/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rimraf dist",
    "prepare": "husky",
    "benchmark": "node benchmarks/performance.js"
  },
  "lint-staged": {
    "*.{ts,js}": "eslint --fix",
    "*.{ts,js,json,md}": "prettier --write"
  },
  "keywords": [
    "defi",
    "cross-chain",
    "sdk",
    "chen-pilot",
    "stellar",
    "multi-signature",
    "typescript"
  ],
  "author": "Chen Pilot Team",
  "license": "ISC",
  "dependencies": {
    "@stellar/stellar-sdk": "^14.4.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "typescript": ">=4.5.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
